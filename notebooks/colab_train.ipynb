 "cells": [
  {
   "cell_type": "markdown",
   "id": "title",
   "metadata": {},
   "source": [
    "# LoRA Fine-tuning en GPU (Google Colab)\n",
    "\n",
    "Este notebook entrena el adapter LoRA para GPT-2 en SST-2 usando la GPU de Colab.\n",
    "\n",
    "**Antes de ejecutar:**\n",
    "1. Asegúrate de que el runtime tiene GPU: *Entorno de ejecución → Cambiar tipo de entorno de ejecución → T4 GPU*\n",
    "2. Crea un repo en GitHub con el código del proyecto y pon la URL abajo.\n",
    "\n",
    "**Flujo:**\n",
    "1. Configura la URL del repo y el número de ejemplos\n",
    "2. Ejecuta todas las celdas en orden\n",
    "3. La última celda descarga el adapter entrenado como `lora_adapter.zip`\n",
    "4. Descomprime en `artifacts/lora_adapter/` en tu máquina local"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "config",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CONFIGURACIÓN ──────────────────────────────────────────────────────────────\n",
    "GITHUB_REPO_URL = \"https://github.com/TU_USUARIO/TU_REPO.git\"  # <-- cambia esto\n",
    "\n",
    "# Número de ejemplos de entrenamiento. 0 = dataset completo (67k, ~10-15 min en T4)\n",
    "MAX_TRAIN_SAMPLES = 0\n",
    "# ───────────────────────────────────────────────────────────────────────────────"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "check-gpu",
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "assert torch.cuda.is_available(), \"GPU no disponible — cambia el runtime a GPU en Entorno de ejecución > Cambiar tipo de entorno de ejecución\"\n",
    "print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
    "print(f\"VRAM total: {torch.cuda.get_device_properties(0).total_memory / 1024**3:.1f} GB\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "clone-repo",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "repo_name = GITHUB_REPO_URL.rstrip('/').split('/')[-1].replace('.git', '')\n",
    "\n",
    "if not os.path.exists(repo_name):\n",
    "    !git clone {GITHUB_REPO_URL}\n",
    "else:\n",
    "    print(f\"Repo '{repo_name}' ya existe, haciendo pull...\")\n",
    "    !git -C {repo_name} pull\n",
    "\n",
    "os.chdir(repo_name)\n",
    "print(f\"Directorio de trabajo: {os.getcwd()}\")\n",
    "!ls"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "install-torch-cuda",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Instalar torch con soporte CUDA 12.4 (compatible con T4/A100/L4 en Colab)\n",
    "!pip install torch --index-url https://download.pytorch.org/whl/cu124 -q\n",
    "\n",
    "# Verificar que CUDA sigue disponible tras la reinstalación\n",
    "import importlib, torch\n",
    "importlib.reload(torch)\n",
    "print(f\"torch {torch.__version__}, CUDA disponible: {torch.cuda.is_available()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "install-requirements",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Instalar el resto de dependencias (torch ya está instalado con CUDA arriba)\n",
    "!pip install transformers==5.12.1 peft==0.19.1 datasets==5.0.0 accelerate==1.14.0 \\\n",
    "             transformer-lens==3.4.0 scikit-learn==1.9.0 umap-learn==0.5.12 \\\n",
    "             matplotlib==3.11.0 pyyaml==6.0.3 -q\n",
    "print(\"Dependencias instaladas.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "verify-env",
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "from transformer_lens import HookedTransformer\n",
    "\n",
    "print(f\"torch: {torch.__version__}\")\n",
    "print(f\"CUDA disponible: {torch.cuda.is_available()}\")\n",
    "print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
    "print(f\"VRAM total: {torch.cuda.get_device_properties(0).total_memory / 1024**3:.1f} GB\")\n",
    "\n",
    "# Verificar que TransformerLens carga GPT-2\n",
    "_ = HookedTransformer.from_pretrained('gpt2')\n",
    "print(\"TransformerLens OK\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "train",
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, os\n",
    "\n",
    "cmd = [\"python\", \"-m\", \"src.train_lora\"]\n",
    "if MAX_TRAIN_SAMPLES and MAX_TRAIN_SAMPLES > 0:\n",
    "    cmd += [\"--max-train-samples\", str(MAX_TRAIN_SAMPLES)]\n",
    "    print(f\"Entrenando con {MAX_TRAIN_SAMPLES} ejemplos...\")\n",
    "else:\n",
    "    print(\"Entrenando con el dataset completo (67k ejemplos)...\")\n",
    "\n",
    "print(f\"Comando: {' '.join(cmd)}\\n\")\n",
    "result = subprocess.run(cmd, capture_output=False, text=True)\n",
    "print(f\"\\nExit code: {result.returncode}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "show-results",
   "metadata": {},
   "outputs": [],
   "source": [
    "import json, pathlib\n",
    "\n",
    "result_path = pathlib.Path('results/train_lora.json')\n",
    "if result_path.exists():\n",
    "    data = json.loads(result_path.read_text())\n",
    "    print(\"=== Resultados del entrenamiento ===\")\n",
    "    for k, v in data.items():\n",
    "        if not k.startswith('_'):\n",
    "            print(f\"  {k}: {v}\")\n",
    "else:\n",
    "    print(\"No se encontró results/train_lora.json\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eval",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Evaluación rápida del modelo afinado\n",
    "print(\"Evaluando el modelo afinado en SST-2 validation...\")\n",
    "!python -m src.eval --adapter artifacts/lora_adapter\n",
    "\n",
    "eval_path = pathlib.Path('results/eval_finetuned.json')\n",
    "if eval_path.exists():\n",
    "    data = json.loads(eval_path.read_text())\n",
    "    print(f\"\\n>>> Accuracy fine-tuned: {data['accuracy']:.4f} ({data['accuracy']*100:.1f}%)\")\n",
    "    print(f\">>> Base accuracy (M0): 0.6170 (61.7%)\")\n",
    "    print(f\">>> Mejora: {(data['accuracy'] - 0.617)*100:+.1f} pp\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "download-adapter",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Comprimir y descargar el adapter\n",
    "import shutil\n",
    "from google.colab import files\n",
    "\n",
    "adapter_dir = pathlib.Path('artifacts/lora_adapter')\n",
    "if adapter_dir.exists():\n",
    "    zip_path = '/content/lora_adapter'\n",
    "    shutil.make_archive(zip_path, 'zip', adapter_dir.parent, adapter_dir.name)\n",
    "    print(f\"Adapter comprimido en {zip_path}.zip\")\n",
    "    files.download(f'{zip_path}.zip')\n",
    "    print(\"\\nDescarga iniciada. Descomprime en artifacts/lora_adapter/ en tu máquina local.\")\n",
    "else:\n",
    "    print(\"ERROR: No se encontró artifacts/lora_adapter — verifica que el entrenamiento terminó bien.\")"
   ]
  }
 ]
}"
